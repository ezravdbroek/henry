---
---

<footer class="footer">
	<div class="footer-inner">
		<div class="footer-logo">
			<span class="logo-text">Henry</span>
			<span class="logo-sub">CALLIGRAPHY</span>
		</div>

		<div class="footer-links">
			<a href="mailto:info@henrycalligraphy.com" class="footer-link">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="4" width="20" height="16" rx="2" />
					<path d="M22 4L12 13L2 4" />
				</svg>
				info@henrycalligraphy.com
			</a>
			<a href="https://www.instagram.com/henrycalligraphy" target="_blank" rel="noopener noreferrer" class="footer-link">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="2" width="20" height="20" rx="5" />
					<circle cx="12" cy="12" r="5" />
					<circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
				</svg>
				@henrycalligraphy
			</a>
			<span class="footer-link location">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
					<circle cx="12" cy="9" r="2.5" />
				</svg>
				<span data-i18n="footer.based">Based in Breda, The Netherlands</span>
			</span>
		</div>

		<div class="footer-bottom">
			<p>&copy; 2026 Henry Calligraphy. <span data-i18n="footer.rights">All rights reserved.</span></p>
		</div>
	</div>
</footer>

<style>
	.footer {
		padding: 3rem 2rem 2rem;
		background-color: var(--color-walnut-dark);
		color: rgba(250, 248, 245, 0.8);
	}

	.footer-inner {
		max-width: var(--max-content);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		text-align: center;
	}

	.footer-logo {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.logo-text {
		font-family: var(--font-heading);
		font-size: 2rem;
		font-style: italic;
		color: var(--color-ivory);
		line-height: 1;
	}

	.logo-sub {
		font-family: var(--font-body);
		font-size: 0.65rem;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: rgba(250, 248, 245, 0.6);
		margin-top: 0.25rem;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 2rem;
	}

	.footer-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: rgba(250, 248, 245, 0.7);
		font-size: 0.85rem;
		transition: color var(--transition-base);
	}

	a.footer-link:hover {
		color: var(--color-ivory);
	}

	.location {
		cursor: default;
	}

	.footer-bottom {
		padding-top: 1.5rem;
		border-top: 1px solid rgba(250, 248, 245, 0.1);
		width: 100%;
	}

	.footer-bottom p {
		font-size: 0.8rem;
		color: rgba(250, 248, 245, 0.4);
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer-links {
			flex-direction: column;
			gap: 1rem;
		}
	}
</style>
