---
---

<section id="services" class="services">
	<div class="services-header fade-in">
		<div class="section-label">
			<span class="label-line"></span>
			<span class="label-text" data-i18n="nav.services">Services</span>
			<span class="label-line"></span>
		</div>
		<h2 data-i18n="services.title">Services</h2>
		<svg class="flourish" viewBox="0 0 200 20" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M0 10 Q 50 0, 100 10 Q 150 20, 200 10" stroke="currentColor" stroke-width="0.75" fill="none"/>
			<circle cx="100" cy="10" r="2" fill="currentColor"/>
		</svg>
	</div>

	<!-- Service 1: Live Calligraphy — image left, text right -->
	<div class="service-block service-block--left fade-in">
		<div class="service-image">
			<img src="/foto8.jpeg" alt="Live calligraphy place cards at an event" loading="lazy" />
			<div class="image-overlay"></div>
			<span class="service-number">01</span>
		</div>
		<div class="service-content">
			<div class="content-inner">
				<h3 data-i18n="services.live.title">Live Bespoke Calligraphy at Location</h3>
				<div class="accent-line"></div>
				<p class="service-intro" data-i18n="services.live.intro">At the location of your choice, I can create chique, handwritten notes, placecards, letters, designed especially for your brand or for the occasion.</p>
				<ul class="selling-points">
					<li>
						<svg class="point-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2z"/></svg>
						<span data-i18n="services.live.point1">Immediate, on-demand customization — a luxury experience clients will not easily forget</span>
					</li>
					<li>
						<svg class="point-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
						<span data-i18n="services.live.point2">Hospitable, culturally aware and communicative, with 10+ years of international experience</span>
					</li>
					<li>
						<svg class="point-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
						<span data-i18n="services.live.point3">A powerful and personal brand statement that sets your event apart</span>
					</li>
				</ul>
			</div>
		</div>
	</div>

	<!-- Divider flourish -->
	<div class="block-divider fade-in">
		<svg viewBox="0 0 2 60" class="divider-line"><line x1="1" y1="0" x2="1" y2="60" stroke="currentColor" stroke-width="0.75"/></svg>
	</div>

	<!-- Service 2: Studio Work — image right, text left -->
	<div class="service-block service-block--right fade-in">
		<div class="service-content">
			<div class="content-inner">
				<h3 data-i18n="services.studio.title">Studio Work</h3>
				<div class="accent-line"></div>
				<p class="service-intro" data-i18n="services.studio.intro">At my studio I can create calligraphy pieces; from placecards, to handwritten envelopes for your wedding, a wedding menu or wedding vows.</p>
				<div class="studio-tags">
					<span class="tag" data-i18n="services.studio.tag1">Placecards</span>
					<span class="tag" data-i18n="services.studio.tag2">Envelopes</span>
					<span class="tag" data-i18n="services.studio.tag3">Wedding Menus</span>
					<span class="tag" data-i18n="services.studio.tag4">Wedding Vows</span>
					<span class="tag" data-i18n="services.studio.tag5">Diplomas</span>
					<span class="tag" data-i18n="services.studio.tag6">Certificates</span>
				</div>
				<p class="service-closing" data-i18n="services.studio.closing">Perhaps you would like to have your official diploma or certificate handwritten by me, we can always discuss the possibilities.</p>
				<span class="note" data-i18n="services.studio.note">Hourly fee upon request</span>
			</div>
		</div>
		<div class="service-image">
			<img src="/foto5.jpg" alt="Gold calligraphy on white card - studio work" loading="lazy" />
			<div class="image-overlay"></div>
			<span class="service-number">02</span>
		</div>
	</div>

	<!-- Portfolio Gallery -->
	<div class="gallery-section fade-in">
		<div class="gallery-label">
			<svg viewBox="0 0 2 40" class="divider-line"><line x1="1" y1="0" x2="1" y2="40" stroke="currentColor" stroke-width="0.75"/></svg>
			<span class="label-text">Portfolio</span>
			<svg viewBox="0 0 2 40" class="divider-line"><line x1="1" y1="0" x2="1" y2="40" stroke="currentColor" stroke-width="0.75"/></svg>
		</div>
		<div class="gallery-grid">
			<div class="gallery-item gallery-item--tall fade-in">
				<img src="/foto4.jpg" alt="Calligraphy place cards with roses" loading="lazy" />
			</div>
			<div class="gallery-item fade-in">
				<img src="/foto6.jpg" alt="Villa Castelletto and Mia & Kenny place cards" loading="lazy" />
			</div>
			<div class="gallery-item fade-in">
				<img src="/foto7.jpeg" alt="Nicolette Bingham and Michael Gorzynski place cards" loading="lazy" />
			</div>
			<div class="gallery-item gallery-item--wide fade-in">
				<img src="/foto9.jpeg" alt="Full table of handwritten calligraphy place cards" loading="lazy" />
			</div>
		</div>
	</div>
</section>

<style>
	.services {
		padding: clamp(4rem, 8vw, 8rem) 0;
		background-color: var(--color-ivory-dark);
		overflow: hidden;
	}

	/* ---- Header ---- */
	.services-header {
		text-align: center;
		margin-bottom: clamp(3rem, 6vw, 5rem);
		padding: 0 clamp(1.5rem, 5vw, 6rem);
	}

	.section-label {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 0.5rem;
	}

	.label-line {
		width: 40px;
		height: 1px;
		background-color: var(--color-walnut);
	}

	.label-text {
		font-family: var(--font-body);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-text-light);
	}

	h2 {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		margin: 0.5rem 0 1.5rem;
		font-style: italic;
	}

	.flourish {
		width: clamp(120px, 15vw, 200px);
		height: auto;
		color: var(--color-walnut);
		opacity: 0.4;
	}

	/* ---- Service Block (alternating layout) ---- */
	.service-block {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		max-width: var(--max-content);
		margin: 0 auto;
	}

	.service-block--right {
		grid-template-columns: 0.85fr 1.15fr;
	}

	.service-image {
		position: relative;
		overflow: hidden;
	}

	.service-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.service-block:hover .service-image img {
		transform: scale(1.04);
	}

	.image-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(74, 50, 40, 0.15) 0%, transparent 60%);
		pointer-events: none;
	}

	.service-number {
		position: absolute;
		bottom: 1.5rem;
		font-family: var(--font-heading);
		font-size: clamp(4rem, 8vw, 7rem);
		font-weight: 300;
		font-style: italic;
		color: rgba(255, 255, 255, 0.55);
		line-height: 1;
		pointer-events: none;
		user-select: none;
	}

	.service-block--left .service-number {
		right: 1.5rem;
	}

	.service-block--right .service-number {
		left: 1.5rem;
	}

	.service-content {
		display: flex;
		align-items: center;
		background-color: var(--color-ivory);
		position: relative;
	}

	.service-block--left .service-content {
		padding: clamp(2rem, 4vw, 4rem) clamp(2rem, 4vw, 4rem) clamp(2rem, 4vw, 4rem) clamp(2.5rem, 5vw, 5rem);
	}

	.service-block--right .service-content {
		padding: clamp(2rem, 4vw, 4rem) clamp(2.5rem, 5vw, 5rem) clamp(2rem, 4vw, 4rem) clamp(2rem, 4vw, 4rem);
	}

	.content-inner {
		width: 100%;
	}

	.service-content h3 {
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 2.5vw, 2rem);
		font-weight: 400;
		color: var(--color-walnut);
		margin: 0 0 1rem;
		line-height: 1.3;
	}

	.accent-line {
		width: 50px;
		height: 1px;
		background-color: var(--color-walnut);
		margin-bottom: 1.5rem;
		opacity: 0.4;
	}

	.service-intro {
		font-size: 0.92rem;
		line-height: 1.85;
		color: var(--color-text);
		margin: 0 0 1.5rem;
	}

	/* Selling points */
	.selling-points {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
	}

	.selling-points li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		font-size: 0.85rem;
		line-height: 1.65;
		color: var(--color-text);
	}

	.point-icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		color: var(--color-walnut);
		opacity: 0.6;
		margin-top: 3px;
	}

	/* Studio tags */
	.studio-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.tag {
		padding: 0.35rem 0.9rem;
		font-size: 0.7rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-walnut);
		border: 1px solid rgba(92, 64, 51, 0.2);
		font-family: var(--font-body);
		transition: background-color var(--transition-base), color var(--transition-base);
	}

	.tag:hover {
		background-color: var(--color-walnut);
		color: var(--color-ivory);
	}

	.service-closing {
		font-size: 0.85rem;
		line-height: 1.75;
		color: var(--color-text-light);
		margin: 0;
	}

	.note {
		display: inline-block;
		margin-top: 1.25rem;
		font-size: 0.78rem;
		font-style: italic;
		color: var(--color-text-light);
		letter-spacing: 0.02em;
	}

	/* ---- Divider ---- */
	.block-divider {
		display: flex;
		justify-content: center;
		padding: 1.5rem 0;
		color: var(--color-walnut);
		opacity: 0.3;
	}

	.divider-line {
		width: 2px;
		height: auto;
	}

	/* ---- Gallery ---- */
	.gallery-section {
		max-width: var(--max-content);
		margin: 0 auto;
		padding: clamp(3rem, 6vw, 5rem) 0 0;
	}

	.gallery-label {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 2.5rem;
		color: var(--color-walnut);
		opacity: 0.5;
	}

	.gallery-label .label-text {
		font-size: 0.65rem;
		letter-spacing: 0.25em;
	}

	.gallery-label .divider-line {
		height: 40px;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-template-rows: auto auto;
		gap: 0.75rem;
	}

	.gallery-item {
		overflow: hidden;
		position: relative;
	}

	.gallery-item::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(74, 50, 40, 0.08) 0%, transparent 50%);
		pointer-events: none;
		transition: opacity 0.4s ease;
	}

	.gallery-item:hover::after {
		opacity: 0;
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		aspect-ratio: 1;
		transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.gallery-item:hover img {
		transform: scale(1.06);
	}

	.gallery-item--tall {
		grid-row: span 2;
	}

	.gallery-item--tall img {
		aspect-ratio: auto;
		height: 100%;
	}

	.gallery-item--wide {
		grid-column: span 2;
	}

	.gallery-item--wide img {
		aspect-ratio: 2 / 1;
	}

	/* ---- Responsive ---- */
	@media (max-width: 900px) {
		.service-block,
		.service-block--right {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.service-block--right .service-content {
			order: 2;
		}

		.service-block--right .service-image {
			order: 1;
		}

		.service-image {
			height: 340px;
		}

		.service-content {
			padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 5vw, 6rem) !important;
		}

		.service-number {
			font-size: 4rem;
		}

		.gallery-grid {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: auto;
		}

		.gallery-item--tall {
			grid-row: span 1;
		}

		.gallery-item--tall img {
			aspect-ratio: 1;
		}

		.gallery-item--wide {
			grid-column: span 2;
		}
	}

	@media (max-width: 480px) {
		.gallery-grid {
			grid-template-columns: 1fr;
		}

		.gallery-item--wide {
			grid-column: span 1;
		}

		.gallery-item--wide img {
			aspect-ratio: 4 / 3;
		}

		.service-image {
			height: 280px;
		}
	}
</style>
